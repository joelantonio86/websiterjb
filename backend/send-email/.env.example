# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env (ele deve estar no .gitignore).

# E-mail (Gmail)
GMAIL_USER=seu-email@gmail.com
GMAIL_PASS=sua-senha-de-app-do-gmail

# JWT (use uma chave longa e aleatória em produção)
JWT_SECRET=sua-chave-secreta-jwt

# Usuários administradores (JSON). Use o script generate-admin-users.js para gerar o JSON.
# ADMIN_USERS=[{"email":"...","password":"...","role":"admin"},...]
ADMIN_USERS=

# Opcional: porta do servidor (padrão 8080)
# PORT=8080

# Opcional: bucket do Google Cloud Storage (uploads usam GCS por omissão)
# GCS_BUCKET_NAME=rjb-admin-files-bucket

# Cloudflare R2 (API S3) — defina STORAGE_PROVIDER=r2 e preencha tudo para usar R2 em vez de GCS nos uploads
# STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=seu_account_id
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# URL pública do bucket (domínio r2.dev ou custom domain, sem barra no fim)
# R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
